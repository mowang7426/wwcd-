name: Build Theos Tweak

# 触发条件：当你推送代码到 main 分支，或者在网页上手动点击运行时触发
on:
  push:
    branches: [ main, master ]
  workflow_dispatch:

jobs:
  build:
    name: Build .deb Package
    runs-on: macos-latest # 使用 macOS 服务器，自带 Xcode 环境，编译 iOS 插件最稳定

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v3

      - name: Prepare Theos Environment
        run: |
          # 克隆 Theos 本体
          git clone --recursive https://github.com/theos/theos.git $HOME/theos
          # 克隆 iOS SDKs
          git clone https://github.com/theos/sdks.git $HOME/theos/sdks
          # 设置环境变量
          echo "THEOS=$HOME/theos" >> $GITHUB_ENV

      - name: Build Tweak (Rootful & Rootless)
        run: |
          # 编译成标准的 .deb
          make package FINALPACKAGE=1
          
          # 清理缓存，准备编译 Rootless 版本 (适用于 Dopamine/Palera1n rootless)
          make clean
          make package FINALPACKAGE=1 THEOS_PACKAGE_SCHEME=rootless
        env:
          THEOS: ${{ env.THEOS }}

      - name: Upload .deb Artifacts
        uses: actions/upload-artifact@v3
        with:
          name: Tweak-Packages
          path: packages/*.deb
